classDiagram
    %% PawPal+ — pet care planning assistant (4-class design)
    %% Task, Pet, Owner are data classes; Scheduler holds the logic.
    %% Tasks belong to Pets; an Owner has many Pets; the Scheduler reads
    %% through the Owner to organize, detect conflicts, and plan all tasks.

    class Task {
        +str description
        +str time
        +int duration_minutes
        +str priority
        +str frequency
        +bool completed
        +Pet pet
        +mark_complete()
        +mark_incomplete()
        +next_occurrence() Task
        +start_dt()
        +end_dt()
        +end_time() str
        +overlaps(other) bool
        +__str__() str
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task)
        +remove_task(task)
        +__str__() str
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +int available_minutes
        +add_pet(pet)
        +remove_pet(pet)
        +all_tasks() list~Task~
        +__str__() str
    }

    class Scheduler {
        +Owner owner
        +list~Task~ scheduled_tasks
        +list~Task~ skipped_tasks
        +int total_minutes
        +all_tasks() list~Task~
        +tasks_for_pet(pet) list~Task~
        +filter_tasks(pet, pet_name, completed, frequency) list~Task~
        +sort_by_time(tasks) list~Task~
        +daily_schedule() list~Task~
        +pending_tasks() list~Task~
        +completed_tasks() list~Task~
        +find_conflicts() list
        +same_pet_conflicts() list
        +cross_pet_conflicts() list
        +describe_conflict(earlier, later) str
        +conflict_warning() str
        +build_plan(available_minutes) list~Task~
        +explain() str
        +summary() str
        -_fits(task, remaining) bool
    }

    Owner "1" o-- "*" Pet : owns
    Pet "1" o-- "*" Task : has
    Task "*" --> "1" Pet : belongs to
    Scheduler --> Owner : reads
